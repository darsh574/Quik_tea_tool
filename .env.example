# ─────────────────────────────────────────────────────────────────────────────
# QuikT Tool — environment variables
# Copy this file to ".env.local" and fill in real values.
# In production, set the SAME keys in Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY. Never expose to the browser. Used for the
# one-time admin user seed script and privileged server routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Assistant (optional) ──────────────────────────────────────────────────
# OpenRouter key for the help chatbot. Server-side only — never shipped to the client.
# Get one at https://openrouter.ai/keys  (rotate the old leaked key!)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# ── Amazon Selling Partner API (optional — fill when the brand provides creds) ─
# One app registration (LWA) covers all regions. Refresh token differs per region.
AMAZON_LWA_CLIENT_ID=amzn1.application-oa2-client...
AMAZON_LWA_CLIENT_SECRET=amzn1.oa2-cs...
AMAZON_REFRESH_TOKEN_NA=Atzr|...
AMAZON_REFRESH_TOKEN_EU=Atzr|...
AMAZON_REFRESH_TOKEN_FE=Atzr|...
# Use the sandbox endpoints while testing (set to "true")
AMAZON_USE_SANDBOX=false
